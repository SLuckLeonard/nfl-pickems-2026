# Copy this file to .env.local and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your Apps → Web App → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Admin player ID — paste the Firebase UID of the player who should have access
# to O/U line editing and admin controls in the Results screen.
# After your first run, open the browser console and run:
#   localStorage.getItem('nfl_player_id')
# Copy the returned string and paste it here.
VITE_ADMIN_PLAYER_ID=
